{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 100,
  "singleQuote": false,
  "jsxSingleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "semi": false,
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "ignorePatterns": [
    "**/node_modules",
    "**/dist",
    "**/*.md",
    "**/*.mdx",
    "**/pnpm-lock.yaml",
    "**/*.d.ts",
    "**/*.d.ts.map",
    "**/android",
    "**/ios",
    "**/patches",
  ],
}
