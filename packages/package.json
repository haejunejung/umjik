{
  "name": "umjik",
  "version": "0.0.1",
  "description": "Animation library for React Native",
  "keywords": [
    "umjik",
    "motion",
    "framer-motion",
    "animation"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && rolldown -c",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --fix .",
    "lint:check": "oxlint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dev": "vitest dev"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "react": "^19.2.4",
    "release-it": "^19.2.4",
    "rolldown": "1.0.0-rc.9",
    "rolldown-plugin-dts": "^0.22.5",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "react": "^16.8 || ^17 || ^18 || ^19"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.28.2"
}
