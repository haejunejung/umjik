{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react", "import"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "react/react-in-jsx-scope": "off",
    "import/no-unassigned-import": "off"
  },
  "env": {
    "browser": true,
    "es2024": true
  },
  "ignorePatterns": [
    "**/node_modules",
    "**/dist",
    "**/*.d.ts",
    "**/*.d.ts.map",
    "**/android",
    "**/ios",
    "**/patches"
  ]
}
