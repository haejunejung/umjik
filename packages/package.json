{
  "name": "umjik",
  "version": "0.0.1",
  "description": "Animation library for React Native",
  "keywords": [
    "animation",
    "framer-motion",
    "motion",
    "umjik"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && rolldown -c",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --fix .",
    "lint:check": "oxlint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dev": "vitest dev"
  },
  "devDependencies": {
    "@storybook/react": "^8.3.5",
    "@storybook/react-native": "^8.3.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-native": "^13.2.0",
    "@types/react": "^18.2.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-native": "0.76.9",
    "react-native-reanimated": "~3.16.7",
    "react-test-renderer": "^18.2.0",
    "release-it": "^19.2.4",
    "rolldown": "1.0.0-rc.9",
    "rolldown-plugin-dts": "^0.22.5",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-native": ">=0.72.0",
    "react-native-reanimated": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.28.2"
}
