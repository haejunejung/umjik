{
  "name": "root",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test": "pnpm --filter umjik test",
    "storybook": "pnpm --filter @umjik/storybook storybook",
    "storybook:ios": "pnpm --filter @umjik/storybook storybook:ios",
    "storybook:android": "pnpm --filter @umjik/storybook storybook:android",
    "storybook:web": "pnpm --filter @umjik/storybook storybook:web",
    "storybook:generate": "pnpm --filter @umjik/storybook storybook-generate",
    "docs": "pnpm --filter @umjik/docs dev",
    "docs:build": "pnpm --filter @umjik/docs build",
    "build": "pnpm --filter umjik build",
    "deploy": "pnpm run test && pnpm run lint && pnpm run build && pnpm --filter umjik publish"
  },
  "devDependencies": {
    "lefthook": "^2.1.1",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "overrides": {
      "react": "^18.2.0",
      "react-dom": "^18.2.0",
      "react-test-renderer": "^18.2.0",
      "@types/react": "^18.2.6",
      "@types/react-dom": "^18.2.0",
      "react-native": "0.76.9"
    }
  }
}
